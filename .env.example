# ── Backend env (set these in Coolify → Environment Variables) ──────────────
# Copy to .env for local dev. NEVER commit the real .env.

# Database (MongoDB Atlas)
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=client_finder_db

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS — comma-separated allowed origins (your Netlify URL). "*" allows all.
CORS_ORIGINS=https://tu-sitio.netlify.app

# LLM providers
OPENAI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=

# Prospecting / enrichment
APOLLO_API_KEY=
HUNTER_API_KEY=
# RUC -> razón social (SUNAT). Define al menos uno para una resolución confiable;
# sin token se intenta scraping de directorios públicos (menos garantizado).
APIS_NET_PE_TOKEN=
DECOLECTA_TOKEN=

# Email (Brevo / Resend / Zoho SMTP)
BREVO_SMTP_USER=
BREVO_SMTP_KEY=
RESEND_API_KEY=
ZOHO_SMTP_HOST=smtppro.zoho.com
ZOHO_SMTP_PORT=587
ZOHO_SMTP_USER=
ZOHO_SMTP_PASSWORD=
OUTBOUND_FROM_EMAIL=
OUTBOUND_FROM_NAME=

# Outbound rate limits
MAX_COMPANIES_PER_DAY=500
MAX_EMAILS_PER_DAY=50
MAX_SENDS_PER_HOUR=10

# AWS S3 (video module assets)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-2

# YouTube / video
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Public URL of the backend itself (OAuth callbacks, etc.)
APP_BASE_URL=https://api.tudominio.com

# ── AI Agent Hub ──────────────────────────────────────────────────────────────
# Text LLM providers (free tier)
# DeepSeek: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=
# Cerebras: https://cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Together AI: https://api.together.ai → Settings → API Keys
TOGETHER_API_KEY=
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# HuggingFace: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Image generation (free tier)
# Prodia: https://app.prodia.com/api
PRODIA_API_KEY=
# Fal.ai: https://fal.ai/dashboard/keys
FAL_API_KEY=

# Audio / TTS (free tier)
# ElevenLabs: https://elevenlabs.io → Profile → API Keys (free: 10k chars/month)
ELEVENLABS_API_KEY=

# Outlook Calendar — Microsoft Graph OAuth2
# Azure Portal → App registrations → create app → copy values below
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://api.tudominio.com/agent/outlook/callback
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MS_TOKEN_ENCRYPTION_KEY=

# WhatsApp via WAHA (docker run -d -p 3000:3000 devlikeapro/waha)
WAHA_URL=http://localhost:3000
WAHA_API_KEY=
# Free stock media for B-roll (imágenes y videos libres intercalados en el video).
# Plan gratuito. Defínela para activar el B-roll.
#   Pexels → https://www.pexels.com/api/  (fotos + videos)
# Música de fondo Creative Commons (gratis) — https://developer.jamendo.com
JAMENDO_CLIENT_ID=
PEXELS_API_KEY=
